{
  "ApiSettings": {
    "SecretKey": "your_secret_key_here" // must be at least 32 characters long for HMACSHA256
  },
  "AutoMapper": {
    "LicenseKey": "your_license_key_here"
  },
  "ConnectionStrings": {
    "DefaultSQLConnection": "Data Source=your_server_name;Initial Catalog=School2;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/SchoolManagement.log",
          "rollingInterval": "Day"
        }
      }
    ]

  }
}
