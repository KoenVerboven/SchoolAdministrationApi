{
  "ApiSettings": {
    "SecretKey": "YourSecretKey"
  },
  "AutoMapper": {
    "LicenseKey": "YourLicenseKey",
  "ConnectionStrings": {
    "DefaultSQLConnection": "Data Source=YourServerName;Initial Catalog=School2;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [ "YourAllowedOrigin" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/SchoolManagement.log",
          "rollingInterval": "Day"
        }
      }
    ]

  }
}
