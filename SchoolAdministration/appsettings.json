{

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/SchoolManagement.log",
          "rollingInterval": "Day"
        }
      }
    ]

  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultSQLConnection": "YourConnectionString"
  },

  "ApiSettings": {
    "SecretKey": "YourSecretKey"
  },

  "AutoMapper": {
    "LicenseKey": "YourLicenseKey"

}
